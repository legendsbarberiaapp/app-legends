rules_version = '2';

// Reglas para Legends Barbería
// Pégalas en: Firebase Console -> Firestore Database -> Rules
//
// Última actualización: 2026-06-06
// Último cambio: SEGURIDAD — /users/{uid} update: el propio usuario ya NO puede
//   cambiar su `role` ni `sedeId` (cerraba escalación de privilegios: cualquiera
//   se auto-ascendía a admin desde DevTools). Solo el admin cambia role/sedeId.
//
// P3 — colección `secciones` (categorías globales de tienda; las
//   gestiona el admin, las lee cualquier logeado). Producto suma `seccionId` y
//   la sede suma `whatsapp` (campos, sin nuevas rules).
//
// P8 — colecciones `gastos` (egresos en efectivo; crea/lee admin
//   o recepcionista de la sede; update/delete admin) y `recordatorios_pago`
//   (pagos fijos por sede; los gestiona el admin; lee admin o recep de la sede).
//
// P7 — colección `pagos_deuda` (abonos de deudas; crea/lee admin
//   o recepcionista de la sede; update/delete admin). La deuda es la venta con
//   esDeuda=true; aquí solo se registra el pago.
//
// P5 — colección `pagos_comision` (pagos de comisión a barberos;
//   crea/edita solo admin; lee admin, el barbero dueño o la recepcionista de la
//   sede). La comisión generada va denormalizada en cada venta (comisionMonto).
//
// F-caja — nuevas colecciones `retiros` (salidas de efectivo de
//   caja; crea admin o recepcionista de su sede, firmado, monto>0) y `config`
//   (ajustes globales doc `config/app`; lee cualquier logeado, escribe admin).
//
// F6-fix — endurecemos rules de F6 contra vandalismo:
//   1. barberos.ratingPromedio en [0,5] + ratingCount entero solo creciente
//      por 1 (evita "rating=5.0 (9999)" desde DevTools).
//   2. resenias.create lee la cita via get() y valida que sea del cliente,
//      esté completada y no haya sido calificada (evita spam y suplantación).
//   3. comentario máx 500 chars server-side (antes solo client-side).
//
//                F6 trajo colección `resenias` y campos rating en barberos.
//                F4-fix bloqueó cambio de `minimo` del stock por recepcionista.
//                F4 trajo colecciones `stock` y `stock_movimientos`.
//                F3-fix endureció ventas (total/subtotal >= 0).
//                F3 trajo `productos` y `ventas`.
//                F2 trajo recepcionista operando citas + walk-ins.
//                F1 trajo sedes y rol recepcionista.
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: verifica si el request está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: lee el rol del usuario que hace la request
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isBarbero() {
      return isSignedIn() && userRole() == 'barbero';
    }

    function isRecepcionista() {
      return isSignedIn() && userRole() == 'recepcionista';
    }

    // Helper: sede asignada a la recepcionista que hace la request
    function recepcionistaSedeId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sedeId;
    }

    // ============================================
    // USERS
    // ============================================
    match /users/{uid} {
      // Cualquier usuario logeado puede leer su propio doc;
      // admin puede leer todos (para el panel de usuarios).
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // Crear: solo uno mismo al registrarse (ensureUserDocument).
      allow create: if isSignedIn() && request.auth.uid == uid;

      // Update:
      // - Admin: cualquier campo (incluido role/sedeId).
      // - El propio usuario: puede actualizar su info, pero NO `role` ni `sedeId`.
      //   Sin esta restricción, cualquier usuario logueado podía auto-ascenderse
      //   a admin (o asignarse sedeId de recepcionista) editando su propio doc
      //   desde DevTools/SDK. El array ADMIN_EMAILS del cliente NO protege esto:
      //   las reglas son lo único que manda.
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'sedeId'])
      );

      allow delete: if isAdmin();
    }

    // ============================================
    // BARBEROS (catálogo)
    // ============================================
    match /barberos/{barberoId} {
      allow read: if isSignedIn();                  // todos ven quién hay
      allow create, delete: if isAdmin();           // solo admin crea/borra

      // Update:
      // - Admin: cualquier campo.
      // - F6 + F6-fix: cualquier usuario logeado, pero SOLO si:
      //     * Toca exclusivamente {ratingPromedio, ratingCount}
      //     * ratingPromedio queda en [0, 5] (un atacante no puede dejarlo en 9999)
      //     * ratingCount es entero positivo y SOLO crece de a 1
      //       (una sola reseña por update — replica la transaction del service).
      //   La clave del fix es el delta = prev + 1: aunque un atacante haga 100
      //   updates seguidos, cada uno solo suma 1 al count, así no puede inflar
      //   reputación con una sola llamada. El promedio sigue acotado a [0,5].
      allow update: if isAdmin() || (
        isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['ratingPromedio', 'ratingCount'])
        && request.resource.data.ratingPromedio is number
        && request.resource.data.ratingPromedio >= 0
        && request.resource.data.ratingPromedio <= 5
        && request.resource.data.ratingCount is int
        && request.resource.data.ratingCount > 0
        && request.resource.data.ratingCount
             == resource.data.get('ratingCount', 0) + 1
      );
    }

    // ============================================
    // SERVICIOS_CORTE y ADICIONALES (catálogos)
    // ============================================
    match /servicios_corte/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /adicionales/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // SEDES (sucursales) — F1: el catálogo lo crea/edita solo el admin.
    // Cualquier usuario logeado lee (para mostrar el nombre en sus pantallas).
    // ============================================
    match /sedes/{sedeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // SECCIONES (categorías globales de la tienda) — P3
    // Las gestiona solo el admin. Todos los logeados leen (cliente las ve en la
    // tienda, recepcionista/admin al organizar productos).
    // ============================================
    match /secciones/{seccionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // PRODUCTOS (catálogo para POS) — F3
    // Solo admin gestiona. Todos los logeados leen (la recepcionista los muestra
    // al cobrar; el cliente podría verlos en su recibo futuro).
    // ============================================
    match /productos/{productoId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // VENTAS (transacciones cerradas) — F3
    // - Crear: solo la recepcionista de la sede (al cobrar o al hacer venta directa).
    //   El admin también puede (para correcciones futuras).
    // - Leer: la recepcionista de la sede; el admin; el cliente dueño (las
    //   asociadas a sus citas); el barbero asignado (para saber lo que vendió).
    // - Update/delete: solo admin (las ventas son inmutables — para corregir
    //   se crea otra venta opuesta en F4+; por ahora bloqueamos).
    // ============================================
    match /ventas/{ventaId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId()) ||
        resource.data.clienteId == request.auth.uid ||
        resource.data.barberoId == request.auth.uid
      );

      allow create: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista()
          && request.resource.data.sedeId == recepcionistaSedeId()
          && request.resource.data.cobradoPor == request.auth.uid
          && request.resource.data.total is number
          && request.resource.data.total >= 0
          && request.resource.data.subtotal is number
          && request.resource.data.subtotal >= 0)
      );

      allow update, delete: if isAdmin();
    }

    // ============================================
    // STOCK (inventario por sede) — F4
    // - Doc id determinístico: `${productoId}_${sedeId}`
    // - Crear: admin (al setear stock inicial) o recepcionista de la sede
    //   (al recibir mercancía si no había doc todavía, o al vender sin
    //    stock inicial pre-existente).
    // - Actualizar: admin o recepcionista de la sede (entrada, venta o ajuste).
    //   La recepcionista NO puede cambiar sedeId/productoId (immutable) NI
    //   el `minimo` (umbral de alerta es decisión del dueño).
    // - Read: todos los logeados (caja muestra disponibilidad al cobrar).
    // - Delete: solo admin.
    // ============================================
    match /stock/{stockId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista() && request.resource.data.sedeId == recepcionistaSedeId())
      );

      allow update: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista()
          && resource.data.sedeId == recepcionistaSedeId()
          && request.resource.data.sedeId == resource.data.sedeId
          && request.resource.data.productoId == resource.data.productoId
          && request.resource.data.minimo == resource.data.minimo)
      );

      allow delete: if isAdmin();
    }

    // ============================================
    // STOCK_MOVIMIENTOS (audit log) — F4
    // - Inmutables: solo se crean, nunca se editan/borran (admin puede).
    // - Crear: admin o recepcionista de la sede, firmado con su uid.
    // - Read: admin o recepcionista de la sede.
    // ============================================
    match /stock_movimientos/{movId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId())
      );

      allow create: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista()
          && request.resource.data.sedeId == recepcionistaSedeId()
          && request.resource.data.creadoPor == request.auth.uid)
      );

      allow update, delete: if isAdmin();
    }

    // ============================================
    // RETIROS (salidas de efectivo de la caja) — F-caja
    // - Crear: admin (cualquier sede) o recepcionista de SU sede, firmado con
    //   su uid y con monto > 0.
    // - Leer: admin (todo) o recepcionista de su sede (para el cuadre).
    // - Update/delete: solo admin (los retiros son inmutables).
    // ============================================
    match /retiros/{retiroId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId())
      );

      allow create: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista()
          && request.resource.data.sedeId == recepcionistaSedeId()
          && request.resource.data.hechoPor == request.auth.uid
          && request.resource.data.monto is number
          && request.resource.data.monto > 0)
      );

      allow update, delete: if isAdmin();
    }

    // ============================================
    // PAGOS_COMISION (pagos de comisión a barberos) — P5
    // - Crear/editar/borrar: solo admin (es quien paga).
    // - Leer: admin (todo), el barbero dueño (barberoId == uid) para ver sus
    //   pagos, o la recepcionista de la sede.
    // ============================================
    match /pagos_comision/{pagoId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.barberoId == request.auth.uid ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId())
      );
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // PAGOS_DEUDA (abonos/saldos de deudas) — P7
    // - Crear/leer: admin (todo) o recepcionista de la sede de la deuda.
    // - Update/delete: solo admin.
    // (La deuda en sí es la venta con esDeuda=true; aquí solo registramos el pago.)
    // ============================================
    match /pagos_deuda/{pagoId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId())
      );
      allow create: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista()
          && request.resource.data.sedeId == recepcionistaSedeId()
          && request.resource.data.registradoPor == request.auth.uid
          && request.resource.data.monto is number
          && request.resource.data.monto > 0)
      );
      allow update, delete: if isAdmin();
    }

    // ============================================
    // GASTOS (egresos en efectivo de la caja) — P8
    // - Crear/leer: admin (todo) o recepcionista de la sede, firmado, monto>0.
    // - Update/delete: solo admin.
    // ============================================
    match /gastos/{gastoId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId())
      );
      allow create: if isSignedIn()
        && request.resource.data.monto is number
        && request.resource.data.monto > 0
        && request.resource.data.concepto is string
        && request.resource.data.concepto.size() > 0
        && (
          isAdmin() ||
          (isRecepcionista()
            && request.resource.data.sedeId == recepcionistaSedeId()
            && request.resource.data.registradoPor == request.auth.uid)
        );
      allow update, delete: if isAdmin();
    }

    // ============================================
    // RECORDATORIOS_PAGO (pagos fijos del negocio, por sede) — P8
    // - Los gestiona solo el admin (crea/edita/borra/marca pagado).
    // - Leer: admin o recepcionista de la sede (por si se muestran en la sede).
    // ============================================
    match /recordatorios_pago/{recId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId())
      );
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // CONFIG (ajustes globales de la app) — F-caja
    // Doc único `config/app`. Lo lee cualquier logeado (para aplicar el ajuste);
    // solo el admin lo escribe (ej: visibilidad de comentarios de reseñas).
    // ============================================
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ============================================
    // RESEÑAS (calificaciones post-corte) — F6 + F6-fix
    // - Crear: solo el cliente dueño con estrellas 1..5, comentario <=500
    //   chars, y la CITA referenciada debe:
    //     * pertenecerle (cita.clienteId == auth.uid)
    //     * estar completada
    //     * no haber sido calificada antes (reviewed != true)
    //   Esto evita spam, suplantación y reviews sobre citas pendientes.
    //   (La transaction del service también valida; aquí lo enforcearmos
    //    server-side para que un atacante con SDK no pueda saltarse.)
    // - Read: todos los logeados (los ratings son públicos en las cards).
    // - Update/delete: solo admin (moderación).
    // ============================================
    match /resenias/{reseniaId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.clienteId == request.auth.uid
                    && request.resource.data.estrellas is int
                    && request.resource.data.estrellas >= 1
                    && request.resource.data.estrellas <= 5
                    && request.resource.data.barberoId is string
                    && request.resource.data.citaId is string
                    && request.resource.data.get('comentario', '').size() <= 500
                    // Validación cruzada con la cita: 1 get() (cacheado por el
                    // engine si se repite). Si el doc no existe, los accesos
                    // de campo evalúan a null/error y la rule falla — deseado.
                    && get(/databases/$(database)/documents/citas/$(request.resource.data.citaId))
                         .data.clienteId == request.auth.uid
                    && get(/databases/$(database)/documents/citas/$(request.resource.data.citaId))
                         .data.estado == 'completada'
                    && get(/databases/$(database)/documents/citas/$(request.resource.data.citaId))
                         .data.get('reviewed', false) != true;

      allow update, delete: if isAdmin();
    }

    // ============================================
    // CITAS (el corazón del flujo de reserva)
    // ============================================
    match /citas/{citaId} {

      // LEER:
      // - el cliente dueño de la cita
      // - el barbero asignado a esa cita
      // - cualquier admin o barbero (para panels internos)
      // - la recepcionista de la misma sede de la cita (F1: read-only)
      // - cualquier usuario autenticado SI la cita está activa (pendiente o
      //   confirmada). Necesario para que el flujo de reserva del cliente
      //   pueda saber qué slots están ocupados por otros. Las citas canceladas
      //   o completadas siguen siendo privadas.
      allow read: if isSignedIn() && (
        resource.data.clienteId == request.auth.uid ||
        resource.data.barberoId == request.auth.uid ||
        isAdmin() ||
        isBarbero() ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId()) ||
        resource.data.estado == 'pendiente' ||
        resource.data.estado == 'confirmada'
      );

      // CREAR:
      // - el cliente para sí mismo (estado nace pendiente; flujo normal de booking)
      // - la recepcionista de la sede, para walk-ins (estado nace confirmada
      //   porque el cliente ya está físicamente en la barbería)
      allow create: if isSignedIn() && (
        (request.resource.data.clienteId == request.auth.uid
          && request.resource.data.estado == 'pendiente')
        ||
        (isRecepcionista()
          && request.resource.data.sedeId == recepcionistaSedeId()
          && (request.resource.data.estado == 'confirmada'
              || request.resource.data.estado == 'pendiente'))
      );

      // NOTA: el estado 'no_show' lo marca el admin (Agenda) o la recepcionista
      // cuando el cliente no se presenta; se trata igual que 'completada' para
      // lecturas.

      // ACTUALIZAR:
      // - admin puede confirmar/cancelar/cualquier transición
      // - el cliente puede cancelar su propia cita
      // - el barbero puede completar/cancelar su cita asignada
      // - la recepcionista puede actuar sobre las citas de SU sede
      //   (confirmar/cancelar/completar/no_show/reagendar)
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.clienteId == request.auth.uid ||
        resource.data.barberoId == request.auth.uid ||
        (isRecepcionista() && resource.data.sedeId == recepcionistaSedeId())
      );

      // BORRAR: solo admin (normalmente se cancela, no se borra).
      allow delete: if isAdmin();
    }
  }
}
